<Project Sdk="Godot.NET.Sdk/4.6.1">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <TargetFramework Condition=" '$(GodotTargetPlatform)' == 'android' ">net9.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Faster.Collections.Pooled" Version="1.0.3" />
    <PackageReference Include="GDTask" Version="2.0.0" />
    <Compile Remove="script_templates/**/*.cs" /> <!-- All .cs files in a directory subtree -->
  </ItemGroup>
</Project>