config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="pond"
run/main_scene="uid://dp58xsa3dpcbo"
config/features=PackedStringArray("4.5", "C#", "Forward Plus")
